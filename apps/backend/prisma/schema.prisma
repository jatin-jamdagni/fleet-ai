// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}
generator prismabox {
  provider                    = "prismabox"
  typeboxImportDependencyName = "elysia"
  typeboxImportVariableName   = "t"
  inputModel                  = true
  output                      = "../src/generated/prismabox"
}


datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Plan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum Role {
  SUPER_ADMIN
  FLEET_MANAGER
  DRIVER
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  IN_TRIP
}

enum TripStatus {
  PENDING
  ACTIVE
  COMPLETED
  FORCE_ENDED
}

enum InvoiceStatus {
  PENDING
  PAID
  VOID
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Tenant {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  plan      Plan      @default(STARTER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  users        User[]
  vehicles     Vehicle[]
  trips        Trip[]
  invoices     Invoice[]
  aiLogs       AILog[]
  manualChunks ManualChunk[]

  @@map("tenants")
}

model User {
  id           String    @id @default(cuid())
  tenantId     String
  email        String    @unique
  passwordHash String
  name         String
  role         Role
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  lastLoginAt  DateTime?

  // Relations
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  vehicle     Vehicle? @relation("AssignedDriver")
  drivenTrips Trip[]   @relation("DriverTrips")
  aiLogs      AILog[]

  @@index([tenantId])
  @@index([email])
  @@index([tenantId, role])
  @@map("users")
}

model Vehicle {
  id               String        @id @default(cuid())
  tenantId         String
  licensePlate     String
  make             String
  model            String
  year             Int
  costPerKm        Decimal       @db.Decimal(10, 4)
  status           VehicleStatus @default(ACTIVE)
  assignedDriverId String?       @unique
  hasManual        Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?

  // Relations
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  assignedDriver User?         @relation("AssignedDriver", fields: [assignedDriverId], references: [id])
  trips          Trip[]
  manualChunks   ManualChunk[]
  invoices       Invoice[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, deletedAt])
  @@map("vehicles")
}

model Trip {
  id         String     @id @default(cuid())
  tenantId   String
  vehicleId  String
  driverId   String
  status     TripStatus @default(PENDING)
  startTime  DateTime   @default(now())
  endTime    DateTime?
  distanceKm Decimal?   @db.Decimal(10, 3)
  // routeGeometry stored as PostGIS LineString — managed via raw SQL
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  // Relations
  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  vehicle  Vehicle   @relation(fields: [vehicleId], references: [id])
  driver   User      @relation("DriverTrips", fields: [driverId], references: [id])
  gpsPings GpsPing[]
  invoice  Invoice?

  @@index([tenantId])
  @@index([vehicleId])
  @@index([driverId])
  @@index([status])
  @@index([tenantId, status])
  @@index([startTime])
  @@map("trips")
}

model GpsPing {
  id        String   @id @default(cuid())
  tripId    String
  // location stored as PostGIS Point — managed via raw SQL
  lat       Float
  lng       Float
  speed     Float
  heading   Float    @default(0)
  timestamp DateTime

  // Relations
  trip Trip @relation(fields: [tripId], references: [id])

  @@index([tripId])
  @@index([tripId, timestamp])
  @@map("gps_pings")
}

model Invoice {
  id          String        @id @default(cuid())
  tenantId    String
  tripId      String        @unique
  vehicleId   String
  driverId    String
  distanceKm  Decimal       @db.Decimal(10, 3)
  costPerKm   Decimal       @db.Decimal(10, 4)
  totalAmount Decimal       @db.Decimal(12, 2)
  currency    String        @default("USD")
  status      InvoiceStatus @default(PENDING)
  generatedAt DateTime      @default(now())
  paidAt      DateTime?

  // Relations
  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  trip    Trip    @relation(fields: [tripId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([generatedAt])
  @@map("invoices")
}

model ManualChunk {
  id         String   @id @default(cuid())
  vehicleId  String
  tenantId   String
  content    String
  // embedding vector(768) — managed via raw SQL after table creation
  chunkIndex Int
  pageNumber Int?
  createdAt  DateTime @default(now())

  // Relations
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  tenant  Tenant  @relation(fields: [tenantId], references: [id])

  @@index([vehicleId])
  @@index([tenantId])
  @@map("manual_chunks")
}

model AILog {
  id              String   @id @default(cuid())
  tenantId        String
  driverId        String
  vehicleId       String
  question        String
  retrievedChunks Json     @default("[]")
  answer          String
  latencyMs       Int
  createdAt       DateTime @default(now())

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id])
  driver User   @relation(fields: [driverId], references: [id])

  @@index([tenantId])
  @@index([driverId])
  @@index([createdAt])
  @@map("ai_logs")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  action     String
  entityType String
  entityId   String
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
