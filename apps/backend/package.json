{
  "name": "backend",
  "version": "1.0.50",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --minify",
    "start": "bun run dist/index.js",
    "check-types": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "db:migrate": "bunx prisma migrate dev",
    "db:seed": "bun run src/db/seed.ts",
    "db:generate": "bunx prisma generate",
    "db:studio": "prisma studio",
    "db:post-migrate": "docker exec -i fleet_postgres psql -U fleet -d fleetai -f /dev/stdin < ../../scripts/db/post_migrate.sql",
    "db:reset": "cd ../.. && bash scripts/db/reset.sh",
    "test": "bun test src --timeout 30000",
    "test:auth": "bun test src/modules/auth/__tests__ --timeout 30000",
    "test:vehicles": "bun test src/modules/vehicles/__tests__ --timeout 30000",
    "test:users": "bun test src/modules/users/__tests__ --timeout 30000",
    "test:trips": "bun test src/modules/trips/__tests__ --timeout 30000",
    "test:billing": "bun test src/modules/billing/__tests__ --timeout 30000",
    "test:lib": "bun test src/lib/__tests__ --timeout 10000",
    "test:watch": "bun test src --watch --timeout 30000"
  },
  "dependencies": {
    "@elysiajs/bearer": "^1.4.3",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/jwt": "^1.4.1",
    "@elysiajs/static": "^1.4.7",
    "@elysiajs/swagger": "^1.3.1",
    "@fleet/shared": "workspace:*",
    "@googlemaps/google-maps-services-js": "^3.4.2",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@react-pdf/renderer": "^4.3.2",
    "@sentry/bun": "^10.42.0",
    "crypto": "^1.0.1",
    "elysia": "latest",
    "elysia-rate-limit": "^4.5.0",
    "eventsource-parser": "^3.0.6",
    "ioredis": "^5.10.0",
    "node-cron": "^4.2.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.19.0",
    "prismabox": "^1.1.26",
    "prom-client": "^15.1.3",
    "resend": "^6.9.3",
    "stripe": "^20.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/node-cron": "^3.0.11",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bun-types": "^1.3.10",
    "prisma": "^7.4.2"
  },
  "module": "src/index.js"
}
